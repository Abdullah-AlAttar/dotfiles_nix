// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "agent_ui_font_size": 16.0,
  "ui_font_family": ".ZedSans",
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Dark Official Icons)",
    "dark": "VSCode Icons for Zed (Dark Official Icons)",
  },
  // "soft_wrap": "editor_width",
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^grep\\b",
            },
            {
              "pattern": "^head\\b",
            },
          ],
        },
      },
    },
    "sidebar_side": "right",
    "dock": "right",
    "play_sound_when_agent_done": "never",
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "model_parameters": [],
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Gruvbox Material",
  },
  "experimental.theme_overrides": {
    "version_control.added": "#00ff00",
    "version_control.deleted": "#ff0000",
    "terminal.background": "#191515",
    "terminal.foreground": "#E9E9F4",
    // Panel/sidebar background
    "panel.background": "#191515",
    "panel.foreground": "#E9E9F4",

    "syntax": {
      "constant.comment.todo": {
        "color": "#FFBD2BFF",
        "background_color": "#FFBD2B1A",
        "font_weight": 600,
      },
      "string.comment.fixme": {
        "color": "#F44747FF",
        "background_color": "#F447471A",
        "font_weight": 600,
      },
      "comment.hack": {
        "color": "#3794FFFF",
        "background_color": "#3794FF12",
        "font_style": "italic",
        "font_weight": 500,
      },
      "comment.note": {
        "color": "#50A14FFF",
        "background_color": "#50A14F12",
        "font_style": "italic",
        "font_weight": 500,
      },
      "comment.error": {
        "color": "#CA1243FF",
        "background_color": "#CA12431A",
        "font_weight": 700,
      },
    },
  },

  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 16.0,
  "buffer_font_weight": 450,
  "buffer_font_features": {
    "calt": true,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "project_panel": {
    // "button": false,
    "dock": "left",
    "entry_spacing": "standard",
  },
  "tabs": {
    "file_icons": true,
  },
  "autosave": "on_focus_change",
  // "buffer_font_family": "CaskaydiaCove Nerd Font",
  "buffer_font_family": "Google Sans Code Monospaced",
  "vertical_scroll_margin": 10,
  "relative_line_numbers": "enabled",
  "show_whitespaces": "all",
  "extend_comment_on_newline": false,
  "terminal": {
    "scroll_multiplier": 2,
    "font_family": "CaskaydiaCove Nerd Font",
    "shell": {
      "program": "/run/current-system/sw/bin/zsh",
    },
  },
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path=",
        ],
      },
    },
  },
  "languages": {
    "YAML": {
      "indent_guides": {
        "coloring": "indent_aware",
        "background_coloring": "indent_aware",
      },
      "tab_size": 2,
    },
    "Go": {
      "language_servers": ["gopls", "golangci-lint"],
    },
  },
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "",
      },
    },
  },
}
